# FonoMundos · Variables de entorno
# Copia este archivo a .env.local y rellena los valores

# Supabase — base de datos de feedback (gratis en supabase.com)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Telegram — alertas en tiempo real a Jose cuando llega un reporte
# Bot token: obtener de @BotFather
# Chat ID: el ID de tu canal/grupo privado (usa @userinfobot para saberlo)
VITE_TG_BOT_TOKEN=123456:ABC-DEF...
VITE_TG_CHAT_ID=-100123456789
